# API Backend (server-only, used by Next.js rewrites for /api/* proxy)
# 不带 NEXT_PUBLIC_ 前缀，不暴露给浏览器
API_BACKEND_URL=http://localhost:8000

# Auth Service (浏览器侧 OAuth 起步，会被注入到 bundle)
NEXT_PUBLIC_AUTH_SERVICE_BASE_URL=http://localhost:8100
NEXT_PUBLIC_AUTH_SERVICE_CLIENT_ID=fusion-client
NEXT_PUBLIC_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Railway / Docker runtime
# PORT=3000
# NODE_ENV=production
