FROM node:20-alpine

WORKDIR /smoke

ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

RUN apk add --no-cache \
  ca-certificates \
  chromium \
  freetype \
  harfbuzz \
  nss \
  ttf-freefont

RUN npm init -y \
  && npm install --no-save --package-lock=false --ignore-scripts --no-audit --no-fund playwright@1.58.2 \
  && npm cache clean --force

ENV PLAYWRIGHT_MODULE_PATH=/smoke/node_modules/playwright/index.js
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
