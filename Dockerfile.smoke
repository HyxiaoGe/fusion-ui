FROM mcr.microsoft.com/playwright:v1.58.2-noble

WORKDIR /smoke

ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

RUN npm init -y \
  && npm install --no-save --package-lock=false --ignore-scripts --no-audit --no-fund playwright@1.58.2 \
  && npm cache clean --force

ENV PLAYWRIGHT_MODULE_PATH=/smoke/node_modules/playwright/index.js
